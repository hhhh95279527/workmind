# server/.env.example
# 复制此文件为 .env，填入真实的 Key

# ── 必填 ────────────────────────────────────────────────────────
# DeepSeek API Key（对话模型）
# 申请地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥

# ── 可选 ────────────────────────────────────────────────────────
# OpenAI API Key（embedding 模型，RAG 功能需要）
# 如果不做 RAG 功能可以不填
OPENAI_API_KEY=sk-你的OpenAI密钥

# 服务端口（默认 3000）
PORT=3000

# 运行环境：development / production
NODE_ENV=development

# 允许跨域的前端地址（多个用逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173

# 使用的对话模型（默认 deepseek-chat）
PRIMARY_MODEL=deepseek-chat

# 使用的 Embedding 模型（默认 text-embedding-3-small）
EMBED_MODEL=text-embedding-3-small

# Chroma 向量数据库地址（RAG 功能需要启动 Chroma）
# 启动命令：docker run -d -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000

# 缓存过期时间（毫秒，默认 30 分钟）
CACHE_TTL=1800000
